{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "core-minimal",
      "displayName": "C-Claw SDK Core Minimal",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/sdk/core-minimal",
      "cacheVariables": {
        "CC_PROFILE": "core-minimal",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "core-minimal",
      "configurePreset": "core-minimal"
    }
  ],
  "testPresets": [
    {
      "name": "core-minimal",
      "configurePreset": "core-minimal",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
